generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                   @id @default(autoincrement())
  username          String                @unique
  password          String
  fullName          String
  phone             String                @unique
  bankName          String
  bankAccount       String
  lineId            String?
  referrerCode      String?
  referredBy        Int?
  status            String                @default("ACTIVE")
  balance           Decimal               @default(0)
  bonusBalance      Decimal               @default(0)
  turnoverLimit     Decimal               @default(0)
  currentTurnover   Decimal               @default(0)
  commissionTurnover Decimal              @default(0)
  commissionCycleStartedAt DateTime?
  betflixUsername   String?               @unique
  betflixPassword   String?
  lastLoginAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  lastActiveAgentId Int?
  sessionToken      String?
  autoDeposit       Boolean               @default(true)
  selectedPromotionId Int?
  selectedPromotionAt DateTime?
  gameSessions      GameSession[]
  promotionLogs     PromotionLog[]
  rewards           RewardClaim[]
  rewardSnapshots   RewardUserSnapshot[]
  selectedPromotion Promotion?            @relation("UserSelectedPromotion", fields: [selectedPromotionId], references: [id])
  transactions      Transaction[]
  trueWalletLogs    TrueWalletLog[]
  externalAccounts  UserExternalAccount[]

  @@index([phone])
  @@index([referrerCode])
  @@index([createdAt])
  @@index([selectedPromotionId])
  @@index([commissionTurnover])
}

model UserExternalAccount {
  id               Int         @id @default(autoincrement())
  userId           Int
  agentId          Int
  externalUsername String
  externalPassword String
  balance          Decimal     @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  agent            AgentConfig @relation(fields: [agentId], references: [id])
  user             User        @relation(fields: [userId], references: [id])

  @@unique([userId, agentId])
  @@index([externalUsername])
}

model Admin {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  password     String
  fullName     String
  phone        String?
  isSuperAdmin Boolean    @default(false)
  roleId       Int?
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         AdminRole? @relation(fields: [roleId], references: [id])
  adminLogs    AdminLog[]
  editLogs     EditLog[]  @relation("AdminEditor")

  @@index([username])
}

model AdminRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admins      Admin[]
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String
  resource  String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model Transaction {
  id               Int             @id @default(autoincrement())
  userId           Int
  type             String
  subType          String?
  amount           Decimal
  balanceBefore    Decimal
  balanceAfter     Decimal
  status           String          @default("PENDING")
  slipImage        String?
  note             String?
  adminId          Int?
  promotionId      Int?
  promotionBonusAmount Decimal?    @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  externalId       String?
  paymentGatewayId Int?
  qrCode           String?
  rawResponse      String?
  referenceId      String?         @unique
  paymentGateway   PaymentGateway? @relation(fields: [paymentGatewayId], references: [id])
  promotion        Promotion?      @relation(fields: [promotionId], references: [id])
  promotionLog     PromotionLog?
  user             User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([promotionId])
  @@index([referenceId])
}

model PaymentGateway {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  config       String
  logo         String?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model EditLog {
  id         Int      @id @default(autoincrement())
  targetType String
  targetId   Int
  field      String
  oldValue   String?
  newValue   String?
  adminId    Int
  createdAt  DateTime @default(now())
  admin      Admin    @relation("AdminEditor", fields: [adminId], references: [id])

  @@index([targetType, targetId])
  @@index([adminId])
  @@index([createdAt])
}

model GameCategory {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  slug        String         @unique
  icon        String?
  description String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  providers   GameProvider[]
}

model GameProvider {
  id             Int          @id @default(autoincrement())
  name           String       @unique
  slug           String       @unique
  logo           String?
  categoryId     Int
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isLobbyMode    Boolean      @default(false)
  defaultAgentId Int?
  games          Game[]
  category       GameCategory @relation(fields: [categoryId], references: [id])
  defaultAgent   AgentConfig? @relation(fields: [defaultAgentId], references: [id])

  @@index([categoryId])
}

model Game {
  id                   Int           @id @default(autoincrement())
  name                 String
  slug                 String        @unique
  providerId           Int?
  thumbnail            String?
  minBet               Decimal       @default(1)
  maxBet               Decimal       @default(10000)
  rtp                  Float         @default(0.96)
  isActive             Boolean       @default(true)
  isHot                Boolean       @default(false)
  isNew                Boolean       @default(false)
  sortOrder            Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  agentId              Int?
  upstreamProviderCode String?
  agent                AgentConfig?  @relation(fields: [agentId], references: [id])
  provider             GameProvider? @relation(fields: [providerId], references: [id])
  sessions             GameSession[]

  @@index([providerId])
  @@index([isActive])
  @@index([agentId])
}

model GameSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  gameId    Int
  betAmount Decimal
  winAmount Decimal
  result    String?
  playedAt  DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([gameId])
  @@index([playedAt])
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  bankName      String
  accountNumber String
  accountName   String
  type          String
  balance       Decimal  @default(0)
  minDeposit    Decimal  @default(0)
  isActive      Boolean  @default(true)
  isShow        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TrueMoneyWallet {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  accountName String
  minDeposit  Decimal  @default(0)
  isActive    Boolean  @default(true)
  isShow      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jwtSecret   String?
}

model TrueWalletLog {
  id              Int      @id @default(autoincrement())
  transactionId   String   @unique
  senderMobile    String
  senderName      String?
  amount          Decimal
  message         String?
  receivedTime    DateTime
  walletId        Int?
  userId          Int?
  transactionDbId Int?
  matchLevel      Int      @default(0)
  status          String   @default("PENDING")
  errorMessage    String?
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@index([senderMobile])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@index([key])
}

model Promotion {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  type        String
  value       Decimal
  minDeposit  Decimal?
  maxBonus          Decimal?
  requiresTurnover  Boolean        @default(false)
  turnoverMultiplier Decimal       @default(1)
  image       String?
  isActive    Boolean        @default(true)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        PromotionLog[]
  selectedUsers User[]       @relation("UserSelectedPromotion")
  transactions Transaction[]
}

model PromotionLog {
  id             Int         @id @default(autoincrement())
  userId         Int
  promotionId    Int
  transactionId  Int?        @unique
  amount         Decimal
  turnoverApplied Decimal    @default(0)
  createdAt      DateTime    @default(now())
  promotion      Promotion   @relation(fields: [promotionId], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([promotionId])
  @@index([createdAt])
}

model Banner {
  id        Int      @id @default(autoincrement())
  position  String   @default("TOP")
  title     String?
  image     String
  link      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  type      String
  title     String?
  content   String
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentConfig {
  id           Int                   @id @default(autoincrement())
  name         String
  apiKey       String?
  apiSecret    String?
  upline       String?
  xApiKey      String?
  xApiCat      String?
  gameEntrance String?
  callbackUrl  String?
  rtp          Float                 @default(0.96)
  minBet       Decimal               @default(1)
  maxBet       Decimal               @default(10000)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  code         String                @unique @default("BETFLIX")
  isMain       Boolean               @default(false)
  games        Game[]
  providers    GameProvider[]
  userAccounts UserExternalAccount[]
}

model DailyReport {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  newUsers        Int      @default(0)
  newUsersDeposit Int      @default(0)
  totalDeposit    Decimal  @default(0)
  depositCount    Int      @default(0)
  totalWithdraw   Decimal  @default(0)
  withdrawCount   Int      @default(0)
  totalBonus      Decimal  @default(0)
  totalBet        Decimal  @default(0)
  totalWin        Decimal  @default(0)
  profit          Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}

model SiteFeature {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   Int?

  @@index([key])
}

model ContactChannel {
  id        Int      @id @default(autoincrement())
  type      String
  name      String
  url       String
  icon      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model CashbackSetting {
  id             Int      @id @default(autoincrement())
  rate           Decimal  @default(5)
  minLoss        Decimal  @default(100)
  maxCashback    Decimal  @default(10000)
  dayOfWeek      Int      @default(1)
  isActive       Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  claimEndHour   Int      @default(23)
  claimStartHour Int      @default(0)
}

model StreakSetting {
  id                 Int      @id @default(autoincrement())
  day                Int      @unique
  minDeposit         Decimal  @default(100)
  bonusAmount        Decimal
  isActive           Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  requiresTurnover   Boolean  @default(false)
  turnoverMultiplier Decimal  @default(1)
}

model CommissionSetting {
  id          Int      @id @default(autoincrement())
  level       Int      @unique
  rate        Decimal
  description String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model TurnoverSetting {
  id          Int      @id @default(autoincrement())
  rate        Decimal  @default(0.5)
  minTurnover Decimal  @default(100)
  maxReward   Decimal  @default(10000)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model RewardClaim {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  amount      Decimal
  periodStart DateTime
  periodEnd   DateTime
  claimedAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([claimedAt])
}

model RewardDailyStat {
  id                 Int      @id @default(autoincrement())
  type               String
  statDate           DateTime
  periodStart        DateTime
  periodEnd          DateTime
  eligibleUserCount  Int      @default(0)
  claimedUserCount   Int      @default(0)
  unclaimedUserCount Int      @default(0)
  claimCount         Int      @default(0)
  totalCalculatedAmount Decimal @default(0)
  totalClaimedAmount Decimal  @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([type, statDate])
  @@index([type, statDate])
}

model RewardUserSnapshot {
  id           Int      @id @default(autoincrement())
  userId       Int
  type         String
  statDate     DateTime
  periodStart  DateTime
  periodEnd    DateTime
  turnover     Decimal  @default(0)
  netLoss      Decimal  @default(0)
  rewardAmount Decimal  @default(0)
  isClaimed    Boolean  @default(false)
  claimedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, type, statDate])
  @@index([type, statDate])
  @@index([type, statDate, isClaimed])
}

model Prefix {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  databaseUrl  String
  adminDomain  String?
  playerDomain String?
  logo         String?
  primaryColor String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model SuperAdmin {
  id          Int             @id @default(autoincrement())
  username    String          @unique
  password    String
  email       String?         @unique
  fullName    String
  isActive    Boolean         @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  logs        SuperAdminLog[]

  @@index([username])
}

model SuperAdminLog {
  id           Int        @id @default(autoincrement())
  superAdminId Int
  action       String
  details      String?
  ip           String?
  createdAt    DateTime   @default(now())
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])

  @@index([superAdminId])
  @@index([createdAt])
}

model SmsWebhookLog {
  id            Int      @id @default(autoincrement())
  rawMessage    String
  messageHash   String   @unique
  parsedData    String?
  amount        Decimal?
  destAccount   String?
  sourceAccount String?
  sourceBank    String?
  sourceName    String?
  matchLevel    Int      @default(0)
  matchedUserId Int?
  transactionId Int?
  status        String   @default("PENDING")
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([messageHash])
  @@index([status])
  @@index([createdAt])
}

model AlertLog {
  id             Int       @id @default(autoincrement())
  type           String
  title          String
  message        String
  userId         Int?
  agentId        Int?
  transactionId  Int?
  status         String    @default("PENDING_REVIEW")
  assignedTo     Int?
  actionUrl      String?
  actionRequired Boolean   @default(true)
  metadata       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resolvedAt     DateTime?

  @@index([type])
  @@index([status])
  @@index([actionRequired])
  @@index([userId])
  @@index([createdAt])
}
